# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development

# SECURITY: Generate a strong SECRET_KEY for production
# Run: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER commit the actual SECRET_KEY to version control!
SECRET_KEY=your-secret-key-change-in-production

# Database Configuration
# Development (SQLite - easiest for local development)
DATABASE_URL=sqlite:///swiftbudget_dev.db

# Development (local PostgreSQL with psycopg3)
# DATABASE_URL=postgresql+psycopg://localhost/swiftbudget_dev

# Production (Supabase - replace with your actual connection string)
# DATABASE_URL=postgresql+psycopg://postgres:password@db.xxx.supabase.co:5432/postgres

# Email Configuration (Gmail SMTP)
# Instructions: https://support.google.com/accounts/answer/185833
# SECURITY: Use App Password, not your actual Gmail password
# SECURITY: In production, use environment-specific secret management
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Currency Configuration
CURRENCY_SYMBOL=MK
CURRENCY_CODE=MWK

# Application Settings
DEBUG=True
TESTING=False

# Session Configuration
# SECURITY: Always use HTTPS in production
SESSION_COOKIE_SECURE=False  # Set to True in production (HTTPS only)
SESSION_COOKIE_HTTPONLY=True  # Prevents JavaScript access (XSS protection)
SESSION_COOKIE_SAMESITE=Lax  # CSRF protection
# Session timeout reduced to 2 hours for security
PERMANENT_SESSION_LIFETIME=7200  # 2 hours in seconds (was 24 hours)

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/swiftbudget.log

# Rate Limiting (optional - uses memory by default)
# For production with multiple servers, use Redis:
# RATELIMIT_STORAGE_URL=redis://localhost:6379

# Google OAuth (optional - for future OAuth implementation)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
